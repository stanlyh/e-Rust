# Base de datos
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm_vehiculos
DATABASE_URL=postgresql://crm_user:crm_password@localhost:5432/crm_vehiculos

# JWT
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-minimo-256-bits
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Servidor
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
RUST_LOG=info

# Frontend (PUBLIC_ es visible en el navegador)
BACKEND_URL=http://localhost:8080
PUBLIC_BACKEND_URL=http://localhost:8080
