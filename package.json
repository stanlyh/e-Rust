{
  "name": "crm-vehiculos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "dev:backend": "cargo watch -x 'run --bin crm-backend' -w backend/src",
    "dev:all": "concurrently \"pnpm dev:backend\" \"pnpm dev\"",
    "build": "pnpm --filter frontend build",
    "preview": "pnpm --filter frontend preview",
    "test": "cargo test --workspace"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
