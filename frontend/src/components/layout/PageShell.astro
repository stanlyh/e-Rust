---
import Sidebar from './Sidebar.astro';
import Header from './Header.astro';
import ToastContainer from '../../islands/ui/ToastContainer';
import '../../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — CRM Vehiculos</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>* { font-family: 'Inter', sans-serif; }</style>
  </head>
  <body class="bg-slate-50 text-gray-900 flex h-screen overflow-hidden">
    <!-- Overlay para cerrar sidebar en movil -->
    <div
      id="sidebar-overlay"
      class="fixed inset-0 bg-black/40 z-30 hidden md:hidden"
    ></div>

    <Sidebar />

    <div class="flex flex-col flex-1 overflow-hidden min-w-0">
      <Header title={title} />
      <main class="flex-1 overflow-auto p-4 md:p-6">
        <slot />
      </main>
    </div>
    <ToastContainer client:load />
  </body>
</html>
