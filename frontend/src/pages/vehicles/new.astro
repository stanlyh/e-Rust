---
import PageShell from '../../components/layout/PageShell.astro';
---
<PageShell title="Agregar Vehiculo">
  <div class="max-w-xl">
    <div class="mb-6">
      <a href="/vehicles" class="text-sm text-gray-500 hover:text-blue-600">← Volver a Vehiculos</a>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <form id="vehicle-form" class="space-y-5">
        <div id="error-msg" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-lg"></div>

        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Marca *</label>
            <input name="make" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Toyota">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Modelo *</label>
            <input name="model" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Hilux">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Año *</label>
            <input name="year" type="number" required min="1990" max="2030" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="2025">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Precio lista *</label>
            <input name="list_price" type="number" required min="0" step="0.01" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Condicion *</label>
            <select name="condition" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
              <option value="new">Nuevo</option>
              <option value="used">Usado</option>
              <option value="certified_used">Certificado</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Combustible</label>
            <select name="fuel_type" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
              <option value="gasoline">Gasolina</option>
              <option value="diesel">Diesel</option>
              <option value="hybrid">Hibrido</option>
              <option value="electric">Electrico</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Transmision</label>
            <select name="transmission" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
              <option value="automatic">Automatica</option>
              <option value="manual">Manual</option>
              <option value="cvt">CVT</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Color exterior</label>
            <input name="color_exterior" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Blanco perla">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Stock / VIN</label>
            <input name="stock_number" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="STK-001">
          </div>
        </div>

        <div class="flex gap-3">
          <a href="/vehicles" class="flex-1 text-center border border-gray-300 text-gray-700 text-sm font-medium py-2 rounded-lg hover:bg-gray-50">Cancelar</a>
          <button type="submit" id="submit-btn" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 rounded-lg disabled:opacity-50">
            Agregar Vehiculo
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { vehiclesApi } from '../../lib/api/vehicles';
    import { initAuth } from '../../lib/auth/store';
    await initAuth();

    const form = document.getElementById('vehicle-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async e => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Guardando...';

      const fd = new FormData(form);
      try {
        const vehicle = await vehiclesApi.create({
          make: fd.get('make') as string,
          model: fd.get('model') as string,
          year: Number(fd.get('year')),
          list_price: Number(fd.get('list_price')),
          condition: fd.get('condition') as any,
          fuel_type: fd.get('fuel_type') as any,
          transmission: fd.get('transmission') as any,
          color_exterior: (fd.get('color_exterior') as string) || undefined,
          stock_number: (fd.get('stock_number') as string) || undefined,
        });
        window.location.href = `/vehicles/${vehicle.id}`;
      } catch {
        errorMsg.textContent = 'Error al crear el vehiculo.';
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Agregar Vehiculo';
      }
    });
  </script>
</PageShell>
