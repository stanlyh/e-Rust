---
import PageShell from '../../components/layout/PageShell.astro';
---
<PageShell title="Detalle de Cliente">
  <div class="mb-4">
    <a href="/clients" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-blue-600 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver a Clientes
    </a>
  </div>

  <div id="client-detail" class="max-w-2xl">
    <!-- Skeleton -->
    <div class="bg-white rounded-xl border border-gray-200 p-6 animate-pulse space-y-4">
      <div class="h-7 bg-gray-100 rounded w-1/2"></div>
      <div class="h-4 bg-gray-100 rounded w-1/3"></div>
      <div class="grid grid-cols-2 gap-4 mt-4">
        <div class="h-4 bg-gray-100 rounded"></div>
        <div class="h-4 bg-gray-100 rounded"></div>
        <div class="h-4 bg-gray-100 rounded"></div>
        <div class="h-4 bg-gray-100 rounded"></div>
      </div>
    </div>
  </div>

  <script>
    import { clientsApi } from '../../lib/api/clients';
    import { initAuth } from '../../lib/auth/store';

    const id = window.location.pathname.split('/').pop()!;
    await initAuth();

    const container = document.getElementById('client-detail')!;

    try {
      const c = await clientsApi.getById(id);

      const createdAt = new Date(c.created_at).toLocaleDateString('es-MX');

      const field = (label: string, value: string | undefined) => value ? `
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide font-medium">${label}</p>
          <p class="text-sm text-gray-800 mt-0.5">${value}</p>
        </div>` : '';

      container.innerHTML = `
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <!-- Header -->
          <div class="p-6 border-b border-gray-100">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-xl font-bold text-gray-900">${c.full_name}</h2>
                ${c.email ? `<p class="text-sm text-gray-500 mt-0.5">${c.email}</p>` : ''}
              </div>
              <a href="/clients/edit/${c.id}"
                class="px-4 py-2 text-sm font-medium rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors shrink-0">
                Editar
              </a>
            </div>
          </div>

          <!-- Datos de contacto -->
          <div class="p-6 grid grid-cols-2 gap-5 border-b border-gray-100">
            ${field('Telefono', c.phone)}
            ${field('Celular', c.mobile)}
            ${field('Documento', c.id_document)}
            ${field('Ciudad', c.city)}
            ${field('Direccion', c.address)}
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide font-medium">Registrado</p>
              <p class="text-sm text-gray-800 mt-0.5">${createdAt}</p>
            </div>
          </div>

          ${c.notes ? `
          <!-- Notas -->
          <div class="p-6">
            <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1.5">Notas</p>
            <p class="text-sm text-gray-700 leading-relaxed">${c.notes}</p>
          </div>` : ''}
        </div>
      `;
    } catch {
      container.innerHTML = `
        <div class="bg-white rounded-xl border border-red-200 p-6 text-center">
          <p class="text-red-500 text-sm font-medium">No se pudo cargar el cliente</p>
          <a href="/clients" class="text-sm text-gray-500 hover:text-blue-600 mt-2 inline-block">Volver al listado</a>
        </div>`;
    }
  </script>
</PageShell>
