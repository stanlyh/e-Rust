---
import PageShell from '../components/layout/PageShell.astro';
import KanbanBoard from '../islands/pipeline/KanbanBoard';
---

<PageShell title="Pipeline de Ventas">
  <div class="flex flex-col h-full">
    <div class="flex items-center justify-between mb-4">
      <p class="text-sm text-gray-500">Arrastra las oportunidades para cambiar su etapa</p>
      <a
        href="/leads/new"
        class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg"
      >
        + Nuevo Lead
      </a>
    </div>
    <KanbanBoard client:load />
  </div>
</PageShell>
